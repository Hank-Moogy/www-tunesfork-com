{
  "name": "tunesfork-sync",
  "version": "0.1.0-alpha.1",
  "description": "Tunesfork Sync — auto-upload Ableton projects on save",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "build:mac": "vite build && electron-packager . \"Tunesfork Sync\" --platform=darwin --arch=universal --out=release --overwrite --icon=assets/icon.icns",
    "build:win": "vite build && electron-packager . \"Tunesfork Sync\" --platform=win32 --arch=x64 --out=release --overwrite --icon=assets/icon.ico"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "@electron/packager": "^18.3.0",
    "vite": "^5.4.0",
    "typescript": "^5.5.0",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "archiver": "^7.0.1",
    "keytar": "^7.9.0",
    "tus-js-client": "^4.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
