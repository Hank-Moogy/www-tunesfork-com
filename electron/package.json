{
  "name": "tunesfork-sync",
  "version": "0.1.0-alpha.1",
  "description": "Tunesfork Sync — auto-upload Ableton projects on save",
  "main": "main.cjs",
  "scripts": {
    "dev:ui": "vite",
    "dev": "VITE_DEV_SERVER_URL=http://localhost:5180 electron .",
    "dev:win": "set VITE_DEV_SERVER_URL=http://localhost:5180&& electron .",
    "dev:all": "concurrently -k -n ui,electron -c blue,green \"npm run dev:ui\" \"wait-on http://localhost:5180 && npm run dev\"",
    "build:ui": "vite build",
    "build:mac": "npm run build:ui && electron-packager . \"Tunesfork Sync\" --platform=darwin --arch=universal --out=release --overwrite",
    "build:win": "npm run build:ui && electron-packager . \"Tunesfork Sync\" --platform=win32 --arch=x64 --out=release --overwrite"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "chokidar": "^3.6.0",
    "fast-xml-parser": "^5.7.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
